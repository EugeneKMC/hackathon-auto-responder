# Server
PORT=8000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/auto_responder

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Microsoft Graph (delegated or app-only auth)
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MS_GRAPH_USER_EMAIL=support@yourcompany.com

# Email poller
EMAIL_POLL_INTERVAL_MS=30000
# Only fetch unread mail received within the last N hours (default 24).
# Stops the poller from grinding through ancient unread in a noisy inbox.
POLL_LOOKBACK_HOURS=24

# Auto-responder gate (optional)
# Comma-separated list of email addresses. Only emails from senders in this
# list are processed by the agent, and the agent JSON is forwarded to ALL
# addresses in the list. Example:
#   ALLOWED_EMAIL=eugene@test.com,russ@test.com
ALLOWED_EMAIL=
